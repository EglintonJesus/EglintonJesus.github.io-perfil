<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detailing Profile | <%= usuario.perfil.nombre %></title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
        body { background-color: #0f1215; color: #e9ecef; font-family: 'Inter', sans-serif; min-height: 100vh; }
        .glass-card { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 20px; }
        
        .foto-perfil { width: 130px; height: 130px; object-fit: cover; border: 3px solid #0dcaf0; padding: 4px; background-color: #000; transition: transform 0.3s ease; }
        .foto-perfil:hover { transform: rotate(3deg) scale(1.05); }

        .img-album { width: 100%; height: 110px; object-fit: cover; border-radius: 10px; transition: 0.3s; cursor: pointer; }
        .img-album:hover { transform: scale(1.05); box-shadow: 0 5px 15px rgba(13, 202, 240, 0.3); }
        
        .btn-cyan { background-color: #0dcaf0; color: #000; font-weight: 600; border: none; transition: 0.3s; }
        .btn-cyan:hover { background-color: #0baccc; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(13, 202, 240, 0.4); }
        
        .form-control-dark { 
            background-color: #000 !important; 
            border: 1px solid #333 !important; 
            color: #fff !important; 
            font-size: 0.85rem; 
            margin-bottom: 8px; 
            border-radius: 8px;
            padding: 0.6rem;
        }
        .form-control-dark::placeholder { color: #ffffff !important; opacity: 0.8; }
        .form-control-dark:focus { 
            background-color: #000 !important; 
            border-color: #0dcaf0 !important; 
            color: #fff !important; 
            box-shadow: 0 0 0 0.25rem rgba(13, 202, 240, 0.25) !important; 
            outline: 0; 
        }

        .list-group-item { background: #000 !important; border: 1px solid #222 !important; color: #fff !important; border-radius: 10px !important; margin-bottom: 8px; transition: 0.3s; }
        .list-group-item:hover { border-color: #0dcaf0 !important; background: #050505 !important; }
        
        .btn-borrar { color: #ff4d4d; transition: 0.3s; padding: 0 8px; font-size: 1.5rem; border: none; background: transparent; line-height: 1; }
        .btn-borrar:hover { transform: scale(1.2); color: #ff1a1a; }

        .carousel-item img { max-height: 80vh; object-fit: contain; background: #000; }
        .carousel-control-prev-icon, .carousel-control-next-icon { background-color: rgba(13, 202, 240, 0.5); border-radius: 50%; padding: 20px; }
        
        /* Estilo para el switch de favorito */
        .form-check-input:checked { background-color: #0dcaf0; border-color: #0dcaf0; }

        .fade-in { animation: fadeIn 0.8s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

<div class="container mt-5 pb-5 fade-in">
    <div class="row">
        <div class="col-md-4">
            <div class="card glass-card shadow-lg mb-4 text-center p-4 border-0">
                <img src="<%= usuario.perfil.foto %>" class="rounded-circle foto-perfil mx-auto shadow" alt="Profile">
                <div class="card-body mt-3">
                    <h4 class="fw-bold text-white"><%= usuario.perfil.nombre %></h4>
                    <p class="text-secondary small mb-4"><%= usuario.perfil.descripcion %></p>
                    
                    <hr class="border-secondary opacity-25">
                    
                    <div class="contact-section text-start">
                        <h6 class="text-uppercase text-info fw-bold small mb-3 text-center">Registrar Contacto</h6>
                        
                        <div class="mb-3">
                            <input type="text" id="nuevoNombre" class="form-control form-control-dark" placeholder="Nombre completo" autocomplete="name">
                            <input type="tel" id="nuevoCelular" class="form-control form-control-dark" placeholder="Celular (WhatsApp)" autocomplete="tel">
                            <input type="email" id="nuevoCorreo" class="form-control form-control-dark" placeholder="Correo electrónico" autocomplete="email">
                            
                            <div class="form-check form-switch mb-3 ms-1">
                                <input class="form-check-input" type="checkbox" id="esFavorito" style="cursor: pointer;">
                                <label class="form-check-label small text-info" for="esFavorito">Marcar como favorito ⭐</label>
                            </div>

                            <button class="btn btn-cyan btn-sm w-100 rounded-pill shadow" id="btnAgregarContacto">
                                GUARDAR EN DIRECTORIO
                            </button>
                        </div>

                        <hr class="border-secondary opacity-25">
                        
                        <h6 class="text-uppercase text-secondary fw-bold small mb-3 text-center">Directorio de Contactos</h6>
                        
                        <ul id="lista-contactos" class="list-group list-group-flush mb-3">
                            </ul>
                        
                        <button id="btnCargarContactos" class="btn btn-outline-secondary btn-sm w-100 rounded-pill">
                            VER FAVORITOS
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <h2 class="mb-4 fw-bold text-white">Galería de Trabajos</h2>
            <div class="row">
                <% usuario.albumes.forEach(album => { %>
                <div class="col-md-6 mb-4">
                    <div class="card glass-card h-100 shadow-sm border-0">
                        <div class="card-header border-0 bg-transparent pt-3 d-flex justify-content-between align-items-center">
                            <h6 class="text-uppercase fw-bold text-info m-0"><%= album.titulo %></h6>
                            <button class="btn btn-link text-danger p-0 text-decoration-none btn-like" data-id="<%= album.id %>">
                                ❤️ <span id="count-<%= album.id %>" class="text-white small">0</span>
                            </button>
                        </div>
                        <div class="card-body">
                            <div class="row g-2 album-container">
                                <% album.fotos.forEach(foto => { %>
                                    <div class="col-4">
                                        <img src="<%= foto %>" class="img-fluid img-album shadow-sm" alt="Detalle">
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="fotoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content glass-card border-0" style="background: rgba(0,0,0,0.95);">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div id="carouselDetailing" class="carousel slide">
                    <div class="carousel-inner" id="carousel-items-container"></div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#carouselDetailing" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#carouselDetailing" data-bs-slide="next">
                        <span class="carousel-control-next-icon"></span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>